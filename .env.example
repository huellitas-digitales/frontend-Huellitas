# ── Backend ───────────────────────────────────────────────────────────────────
# URL donde corre el backend NestJS
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Frontend (URL pública del sitio) ─────────────────────────────────────────
# Se usa para generar los QR de emergencia y los links de compartir
# En producción: https://huellitas-digitales.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Cloudinary (subida de imágenes) ──────────────────────────────────────────
# Crea una cuenta en https://cloudinary.com y obtén estos datos en el Dashboard
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=tu_cloud_name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=tu_upload_preset
